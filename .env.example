# API PAC Qualidade — variáveis de ambiente (dev local / docker)

# Servidor
API_PAC_QUALITY_PORT=8010
API_PAC_QUALITY_PUBLISH_PORT=8010
API_PAC_QUALITY_ENV=development
LOG_LEVEL=INFO

# Prefixo público (deixe vazio — nginx expõe na raiz do subdomínio)
API_PAC_ROOT_PATH=

# URL pública (CORS + documentação / OpenAPI do agente)
PUBLIC_BASE_URL=https://pac-api.minhadelpi.com.br

# Nginx (docker compose deste repo)
NGINX_HTTP_PORT=80

# Auth / Keycloak (mesmo padrão api-delpi — URLs públicas da Minha DELPI em produção)
KEYCLOAK_JWKS_URL=
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
JWT_ALGORITHMS=RS256
CORE_API_URL=https://www.minhadelpi.com.br/core-api

# PostgreSQL de plugins (mesmo banco da api-delpi)
PLUGINS_DB_HOST=localhost
PLUGINS_DB_PORT=5432
PLUGINS_DB_NAME=delpi_plugins
PLUGINS_DB_USER=
PLUGINS_DB_PASSWORD=
PLUGINS_DB_CONNECT_TIMEOUT=5
PLUGINS_DB_SSLMODE=prefer

# Evidências PAC (mesmo diretório recomendado da api-delpi em produção)
PAC_EVIDENCE_UPLOAD_DIR=/app/data/pac-quality-evidences

# Delegação transacional → api-delpi (S2S)
# PAC_DELEGATE_TRANSACTIONAL_TO_API_DELPI=false
# API_DELPI_BASE_URL=http://api-delpi:8000
# API_DELPI_INTERNAL_SERVICE_TOKEN=
# API_DELPI_TIMEOUT_SECONDS=60
