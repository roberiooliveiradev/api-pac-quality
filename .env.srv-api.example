# =============================================================================
# API PAC Qualidade — srv-api (produção)
# =============================================================================
# Uso no servidor:
#   cd ~/projetos/api-pac-quality
#   cp .env.srv-api.example .env
#   # Cole PLUGINS_DB_PASSWORD do delpi-central (ver abaixo)
#   nano .env
#
# Subdomínio Cloudflare (ainda não criado):
#   docs/cloudflare-subdominio-pac-api.md
#
# Senhas — copiar do delpi-central no MESMO servidor:
#   grep -E '^PLUGINS_DB_(USER|PASSWORD|NAME)=' ~/projetos/delpi-central/infra/.env
# =============================================================================

# --- Servidor API (porta só interna ao Docker; não conflita no host) ---
API_PAC_QUALITY_PORT=8010
API_PAC_QUALITY_ENV=production
LOG_LEVEL=INFO
TZ=America/Sao_Paulo

# Sem prefixo — nginx expõe na raiz do subdomínio
API_PAC_ROOT_PATH=

# URL pública do subdomínio (agente GPT + CORS)
PUBLIC_BASE_URL=https://pac-api.minhadelpi.com.br

# --- Nginx (porta no HOST) ---
# srv-api: porta 80 já é do delpi-gateway — use outra porta e roteie no cloudflared.
# Verifique porta livre: ss -tlnp | grep -E ':8082 |:8090 '
NGINX_HTTP_PORT=8082

# --- Keycloak / JWT (Minha DELPI produção) ---
KEYCLOAK_REALM=delpi
KEYCLOAK_AUDIENCE=delpi-central
KEYCLOAK_ISSUER=https://minhadelpi.com.br/auth/realms/delpi
KEYCLOAK_JWKS_URL=https://minhadelpi.com.br/auth/realms/delpi/protocol/openid-connect/certs
JWT_ALGORITHMS=RS256

# RBAC — Core API pública (valida permissões quality-action-plans.*)
CORE_API_URL=https://minhadelpi.com.br/core-api
DELPI_AUTH_CORE_API_URL=https://minhadelpi.com.br/core-api

# --- PostgreSQL plugins (mesmo banco da api-delpi) ---
# Host postgres-plugins só funciona se o container api-pac estiver na rede
# Docker do delpi-central (ver docker-compose.override.srv-api.example.yml).
# Alternativa: IP do host + porta publicada do Postgres (se houver).
PLUGINS_DB_HOST=postgres-plugins
PLUGINS_DB_PORT=5432
PLUGINS_DB_NAME=plugins_hub
PLUGINS_DB_USER=plugins_user
PLUGINS_DB_PASSWORD=COLE_AQUI_O_MESMO_VALOR_DE_delpi-central_infra_.env
PLUGINS_DB_CONNECT_TIMEOUT=5
PLUGINS_DB_SSLMODE=prefer
