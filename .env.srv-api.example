# =============================================================================
# API PAC Qualidade — srv-api (produção)
# =============================================================================
# Uso no servidor:
#   cd ~/projetos/api-pac-quality
#   cp .env.srv-api.example .env
#   # Cole PLUGINS_DB_PASSWORD e tokens do delpi-central (ver abaixo)
#   nano .env
#   cp docker-compose.override.srv-api.example.yml docker-compose.override.yml
#   docker compose up -d --build
#
# Subdomínio Cloudflare: docs/cloudflare-subdominio-pac-api.md
#   https://pac-api.minhadelpi.com.br
#
# Senhas e tokens — copiar do delpi-central no MESMO servidor:
#   grep -E '^(PLUGINS_DB_(USER|PASSWORD|NAME)|API_DELPI_INTERNAL_SERVICE_TOKEN|CORE_API_INTEGRATIONS_SERVICE_TOKEN)=' \
#     ~/projetos/delpi-central/infra/.env
# =============================================================================

# --- Servidor API (porta só interna ao Docker; não conflita no host) ---
API_PAC_QUALITY_PORT=8010
API_PAC_QUALITY_ENV=production
LOG_LEVEL=INFO
TZ=America/Sao_Paulo

# Sem prefixo — nginx expõe na raiz do subdomínio
API_PAC_ROOT_PATH=

# URL pública do subdomínio (agente GPT + CORS)
PUBLIC_BASE_URL=https://pac-api.minhadelpi.com.br

# --- Nginx (porta no HOST) ---
# srv-api: porta 80 já é do delpi-gateway — use outra porta e roteie no cloudflared.
# Verifique porta livre: ss -tlnp | grep -E ':8082 |:8090 '
NGINX_HTTP_PORT=8082

# Chave API para ChatGPT Custom GPT (Actions — Bearer ou X-Api-Key)
# Gerar: openssl rand -hex 32
PAC_QUALITY_API_KEY=

# --- Delegação CRUD → api-delpi (rede Docker delpi-central) ---
PAC_DELEGATE_TRANSACTIONAL_TO_API_DELPI=true
API_DELPI_BASE_URL=http://delpi-api-delpi:8000
API_DELPI_INTERNAL_SERVICE_TOKEN=COLE_DO_delpi-central_infra_.env
API_DELPI_TIMEOUT_SECONDS=60

# --- Core API — diretório assignable users (pac_search_assignable_users) ---
CORE_API_BASE_URL=http://delpi-core-api:8000
CORE_API_INTEGRATIONS_SERVICE_TOKEN=COLE_DO_delpi-central_infra_.env

# --- PostgreSQL plugins (mesmo banco da api-delpi) ---
# Host postgres-plugins só funciona com docker-compose.override na rede infra_delpi-network.
PLUGINS_DB_HOST=postgres-plugins
PLUGINS_DB_PORT=5432
PLUGINS_DB_NAME=plugins_hub
PLUGINS_DB_USER=plugins_user
PLUGINS_DB_PASSWORD=COLE_AQUI_O_MESMO_VALOR_DE_delpi-central_infra_.env
PLUGINS_DB_CONNECT_TIMEOUT=5
PLUGINS_DB_SSLMODE=prefer

# Evidências (volume compartilhado com api-delpi se necessário)
PAC_EVIDENCE_UPLOAD_DIR=/app/data/pac-quality-evidences
